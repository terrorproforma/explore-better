    "verify:pane-activity": "node scripts/pane-activity-ui-smoke.mjs",
    "verify:dual-pane-safety": "node scripts/dual-pane-safety-ui-smoke.mjs",
    "verify:layout": "node scripts/layout-verify.mjs",
    "verify:pane-layout-no-scrollbars": "node scripts/pane-layout-no-scrollbars-smoke.mjs",
    "verify:size-analysis-ui": "node scripts/size-analysis-ui-smoke.mjs",
    "verify:size-analysis-perf": "node scripts/size-analysis-perf-smoke.mjs",
    "verify:size-analysis-cancel": "node scripts/size-analysis-cancel-smoke.mjs",
    "verify:large-folder-ui": "node scripts/large-folder-ui-verify.mjs",
    "verify:large-folder-100k-ui": "node scripts/large-folder-ui-verify.mjs --count=100000 --viewports=desktop --output=large-folder-100k-ui-latest.json --screenshot-prefix=large-folder-100k-ui",
    "verify:keyboard-workflows-ui": "node scripts/keyboard-workflows-ui-smoke.mjs",
    "verify:command-center-ui": "node scripts/command-center-ui-smoke.mjs",
    "verify:accessibility": "node scripts/accessibility-verify.mjs",
    "verify:terminal": "node scripts/terminal-verify.mjs",
    "verify:mcp-contract": "node scripts/mcp-contract-smoke.mjs",
    "verify:mcp-security": "node scripts/mcp-security-smoke.mjs",
    "verify:mcp-context": "node scripts/mcp-context-smoke.mjs",
    "verify:mcp-analysis": "node scripts/mcp-analysis-smoke.mjs",
    "verify:mcp-operations": "node scripts/mcp-operations-smoke.mjs",
    "verify:mcp-clients": "node scripts/mcp-clients-smoke.mjs",
    "verify:mcpb": "node scripts/mcpb-smoke.mjs",
    "verify:mcp-performance": "node scripts/mcp-performance-smoke.mjs",
    "verify:mcp-value": "node scripts/mcp-value-benchmark.mjs",
