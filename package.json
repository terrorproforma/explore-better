    "prepackage:dir": "npm run build:renderer && npm run build:native-helper && npm run build:mcp-server",
    "package:dir": "electron-builder --dir",
    "prepackage:win": "npm run build:renderer && npm run build:native-helper && npm run build:mcp-server",
    "package:win": "electron-builder --win portable",
    "prepackage:installer": "npm run build:renderer && npm run build:native-helper && npm run build:mcp-server",
    "package:installer": "electron-builder --win nsis"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "electron": "^42.6.1",
    "electron-builder": "^26.15.3",
    "esbuild": "0.28.1",
    "lucide-static": "^1.24.0",
    "playwright-core": "^1.61.1",
    "yazl": "3.3.1"
  },
  "build": {
    "appId": "io.github.terrorproforma.explorebetter",
    "productName": "Explore Better",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://github.com/terrorproforma/explore-better/releases/latest/download"
      }
    ],
    "files": [
      "electron-main.mjs",
      "electron-preload.cjs",
      "mcp-bridge-service.mjs",
      "mcp-client-config.mjs",
      "mcp/**/*",
      "terminal-service.mjs",
      "server.mjs",
      "native/bin/**/*",
      "public/**/*",
      "README.md",
      "USER_MANUAL.md",
      "RELEASE_NOTES.md",
      "LICENSE",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "native/bin/explore-better-fs.exe",
        "to": "native/explore-better-fs.exe"
      },
      {
        "from": "native/bin/ExploreBetterMcp.exe",
        "to": "native/ExploreBetterMcp.exe"
      }
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": true,
      "target": [
        "dir",
        "portable",
        "nsis"
      ],
      "artifactName": "ExploreBetter-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "ExploreBetter-${version}-${arch}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "ExploreBetter-${version}-${arch}-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Explore Better"
    }
  },
  "dependencies": {
    "@iarna/toml": "2.2.5",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "electron-updater": "^6.8.9",
    "jsonc-parser": "3.3.1",
    "node-pty": "1.1.0",
    "yauzl": "^3.4.0"
  }
}
