    "verify:background-priority": "node scripts/background-priority-smoke.mjs",
    "verify:background-index-cancel": "node scripts/background-index-cancel-smoke.mjs",
    "verify:background-index-corruption": "node scripts/background-index-corruption-smoke.mjs",
    "verify:background-index-token-search": "node scripts/background-index-token-search-smoke.mjs",
    "verify:speed-index-ui": "node scripts/speed-index-ui-smoke.mjs",
    "verify:search-background-ui": "node scripts/search-background-ui-smoke.mjs",
